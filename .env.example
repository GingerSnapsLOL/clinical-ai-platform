
# General
ENV=dev
LOG_LEVEL=INFO

# Postgres
POSTGRES_USER=clinical_ai
POSTGRES_PASSWORD=clinical_ai
POSTGRES_DB=clinical_ai
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

REDIS_HOST=redis
REDIS_PORT=6379

QDRANT_HOST=qdrant
QDRANT_HTTP_PORT=6333

GATEWAY_PORT=8000
ORCHESTRATOR_PORT=8001
PII_SERVICE_PORT=8002
NER_SERVICE_PORT=8003
RETRIEVAL_SERVICE_PORT=8004
SCORING_SERVICE_PORT=8005
FRONTEND_PORT=3000

# CORS origins for local dev (comma-separated)
CORS_ORIGINS=http://localhost:3000

# Service URLs (internal docker network)
PII_SERVICE_URL=http://pii-service:8020
NER_SERVICE_URL=http://ner-service:8030
RETRIEVAL_SERVICE_URL=http://retrieval-service:8040
SCORING_SERVICE_URL=http://scoring-service:8050
ORCHESTRATOR_URL=http://orchestrator:8010

# LLM server (optional later)
LLM_BASE_URL=http://llm-service:8080

# Orchestrator: skip LLM and return "Insufficient data" when retrieval is weak
# (scores are cross-encoder logits when retrieval uses rerank=true; tune MIN_TOP_SCORE for your env)
ORCHESTRATOR_RETRIEVAL_RELEVANCE_GATE=true
ORCHESTRATOR_RETRIEVAL_MIN_TOP_SCORE=1.0
ORCHESTRATOR_RETRIEVAL_MIN_TOP_SNIPPET_CHARS=24

# Orchestrator: optional Redis caching (best-effort; cache failures never block answering)
ORCHESTRATOR_CACHE_ENABLED=false
ORCHESTRATOR_RETRIEVAL_CACHE_TTL_SEC=300
ORCHESTRATOR_ANSWER_CACHE_TTL_SEC=900






